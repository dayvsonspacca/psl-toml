{
    "name": "dayvsonspacca/psl-toml",
    "description": "A TOML parser for PHP built on top of azjezz/psl",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dayvson Spacca",
            "email": "spacca.dayvson@gmail.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit --testdox",
        "test:coverage": "vendor/bin/phpunit --coverage-html public --testdox",
        "lint": "vendor/bin/mago lint",
        "lint:fix": "vendor/bin/mago lint --fix",
        "fmt": "vendor/bin/mago fmt",
        "fmt:check": "vendor/bin/mago fmt --dry-run",
        "analyze": "vendor/bin/mago analyze",
        "check": [
            "@fmt:check",
            "@lint",
            "@analyze",
            "@test"
        ]
    },
    "require": {
        "php": "^8.4",
        "azjezz/psl": "^4.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "carthage-software/mago": "^1.12.0"
    },
    "autoload": {
        "psr-4": {
            "PslToml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PslToml\\Tests\\": "tests/"
        }
    }
}
